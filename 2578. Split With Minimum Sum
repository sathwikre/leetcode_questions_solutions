class Solution {
    public int splitNum(int num) {
        ArrayList<Integer> arr=new ArrayList<>();
        while(num>0){
            int rem=num%10;
            arr.add(rem);
            num=num/10;
        }
        Collections.sort(arr);
        int s1=0;
        int s2=0;
        for(int i=0;i<arr.size();i+=2){
            s1=s1*10+arr.get(i);
        }
         for(int i=1;i<arr.size();i+=2){
            s2=s2*10+arr.get(i);
        }
        return s1+s2;
    }
}
