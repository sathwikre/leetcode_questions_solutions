class Solution {
    public int rangeSum(int[] nums, int n, int left, int right) {
        int s=n*(n+1)/2;
        int[] arr=new int[s];
        int k=0;
        for(int i=0;i<n;i++){
            int cur=0;
           
            for(int j=i;j<n;j++){
                cur=cur+nums[j];
                arr[k++]=cur;
            }
        }
       Arrays.sort(arr);
       int sum=0;
        for(int i=left-1;i<right;i++){
           int MOD = 1000000007;
           sum = (sum + arr[i]) % MOD;
        }
        return sum;
    }
}
