class Solution {
    public long gcdSum(int[] nums) {
        int mi=-1;
        int[] arr=new int[nums.length];
        for(int i=0;i<nums.length;i++){
            mi=Math.max(mi,nums[i]);
            arr[i]=gcd(nums[i],mi);
        }
        Arrays.sort(arr);
        long sum=0;
        int i=0;
        int j=arr.length-1;
        while(i<arr.length/2){
            sum+=gcd(arr[i],arr[j]);
            i++;
            j--;
        }
        return sum;
    }
    static int gcd(int a,int b){
        if(a==0){
            return b;
        }
        return gcd(b%a,a);
    }
}
