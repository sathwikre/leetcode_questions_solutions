class Solution {
    public int[] findDegrees(int[][] matrix) {
        return find(matrix);
    }
    static int[] find(int[][] arr){
        int[] ans=new int[arr.length];
        int j=0;
        for(int[] mat:arr){
            int sum=0;
            for(int i=0;i<mat.length;i++){
                sum+=mat[i];
            }
            ans[j]=sum;
            j++;
        }
        return ans;
    }
}
