class Solution {
    public boolean validMountainArray(int[] arr) {
        if(arr.length<=2) return false;
        int step=0;
       int h=0;
        for(int i=0;i<arr.length-1;i++){
            if(step==0){
               if(arr[i] < arr[i+1]){
                    h++; 
                } else if(arr[i] > arr[i+1]) {
                  
                    if (h == 0) return false; 
                    step = 1; 
                } else if(arr[i] == arr[i+1]) {
                    return false; 
                }
            }else{
                if(arr[i]<=arr[i+1]){
                    return false;
                }
            }
        }
        return step==1;
    }
}
