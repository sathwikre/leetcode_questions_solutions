class Solution {
    public int minElement(int[] nums) {
        return find(nums);
    }
    static int find(int[] arr){
        int min=Integer.MAX_VALUE;
        for(int i=0;i<arr.length;i++){
            int val=digitsum(arr[i]);
            if(min>val){
                min=val;
            }
        }
        return min;

    }
    static int digitsum(int n){
        int sum=0;
        while(n>0){
            sum+=n%10;
            n=n/10;
        }
        return sum;
    }
}
