/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean isCousins(TreeNode root, int x, int y) {
        TreeNode xx=findnode(root,x);
        TreeNode yy=findnode(root,y);
        return (level(root,xx,0)==level(root,yy,0)&&!issibling(root,xx,yy));
    }
    static boolean issibling(TreeNode root,TreeNode x,TreeNode y){
        if(root==null){
            return false;
        }
        return ((root.left==x&&root.right==y)||(root.left==y&&root.right==x)||issibling(root.left,x,y)||issibling(root.right,x,y));
    }
    static TreeNode findnode(TreeNode node,int x){
        if(node==null){
            return null;
        }
        if(node.val==x){
            return node;
        }
        TreeNode n=findnode(node.left,x);
        if(n!=null){
            return n;
        }
        return findnode(node.right,x);
    }
    static int level(TreeNode root,TreeNode x,int lev){
        if(root==null){
            return 0;
        }
        if(root.val==x.val){
            return lev;
        }
        int v=level(root.left,x,lev+1);
        if(v!=0){
            return v;
        }
        return level(root.right,x,lev+1);
    }
}
