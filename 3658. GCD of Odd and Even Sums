class Solution {
    public int gcdOfOddEvenSums(int n) {
        int n1=1;
        int n2=2;
        int s1=0;
        int s2=0;
        for(int i=0;i<n;i++){
            s1+=n1;
            s2+=n2;
            n1=n1+2;
            n2=n2+2;
        }
        return gcd(s1,s2);
    }
     static int gcd(int a,int b){
        if(b==0){
            return a;
        }
        return gcd(b,a%b);
    }
}
