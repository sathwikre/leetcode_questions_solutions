class Solution {
    public int[] circularGameLosers(int n, int k) {
       boolean[]  arr=new boolean[n];
       int cur=0;
       arr[cur]=true;
       int j=1;
       while(true){
       cur=(cur+(j*k))%n;
        if(arr[cur]==true){
            break;
        }
        arr[cur]=true;
        j++;
       }
       ArrayList<Integer> a=new ArrayList<>();
       for(int i=0;i<arr.length;i++){
        if(!arr[i]){
            a.add(i+1);
        }
       }
       int[] ans=new int[a.size()];
       for(int i=0;i<a.size();i++){
        ans[i]=a.get(i);
       }
       return ans;
    }
}
