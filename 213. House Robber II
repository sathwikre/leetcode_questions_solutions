class Solution {
    public int rob(int[] nums) {
        if(nums.length==1){
            return nums[0];
        }
        int[] a1=new int[nums.length-1];
        int[] a2=new int[nums.length-1];
        int j=0;
        for(int i=1;i<nums.length;i++){
            a1[j++]=nums[i];
        }
        int k=0;
        for(int i=0;i<nums.length-1;i++){
            a2[k++]=nums[i];
        }
        int[] dp=new int[nums.length-1];
        Arrays.fill(dp,-1);
        int[] dp1=new int[nums.length-1];
        Arrays.fill(dp1,-1);        
        return Math.max(find(a1,a1.length-1,dp),find(a2,a2.length-1,dp1));
    }
    static int find(int[] arr,int i,int[] dp){
        if(i==0){
            return arr[0];
        }
        if(i<0) return 0;
        if(dp[i]!=-1) return dp[i];
        int left=0,right=0;
       
        left=arr[i]+find(arr,i-2,dp);
        right=find(arr,i-1,dp);
        return dp[i]=Math.max(right,left);
    }
}
