class Solution {
    public boolean isMonotonic(int[] arr) {
        if(arr[0]<=arr[arr.length-1]){
            return inc(arr);
        }else{
            return dec(arr);
        }
    }
    static boolean dec(int[] arr){
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]<arr[i+1]){
                return false;
            }
        }
        return true;
    }
    static boolean inc(int[] arr){
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]>arr[i+1]){
                return false;
            }
        }
        return true;
    }
}
