class Solution {
    public int divisorSubstrings(int num, int k) {
        int c=0;
        String s=num+"";
        for(int i=0;i<s.length()-k+1;i++){
            int sub=Integer.parseInt(s.substring(i,i+k));
            if(sub==0){
                continue;
            }
            if(num%sub==0){
                c++;
            }

        }
        return c;
    }
}
