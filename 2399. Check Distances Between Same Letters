class Solution {
    public boolean checkDistances(String s, int[] distance) {
        int[] arr=new int[26];
        for(int i=0;i<arr.length;i++){
            arr[i]=-1;
        }
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            int ind=ch-'a';
            if(arr[ind]==-1){
                arr[ind]=i;
            }else{
                int dis=i-arr[ind]-1;
                if(dis!=distance[ind]){
                    return false;
                }
            }
        }
       
       return true;
    }
}
