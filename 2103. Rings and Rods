class Solution {
    public int countPoints(String rings) {
       boolean[][] arr=new boolean[10][3];
       int c=0;
       for(int i=0;i<rings.length();i+=2){
            char ch=rings.charAt(i);
            int v=rings.charAt(i+1)-'0';
            if(ch=='R'){
                arr[v][0]=true;
            }
            if(ch=='G'){
                arr[v][1]=true;
            }
            if(ch=='B'){
                arr[v][2]=true;
            }
       }
       for(int i=0;i<arr.length;i++){
           int h=0;
            for(int j=0;j<3;j++){
                if(arr[i][j]){
                    h++;
                }
            }
            if(h==3){
                c++;
            }
       }
       return c;
    }
}
