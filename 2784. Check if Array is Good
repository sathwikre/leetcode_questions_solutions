class Solution {
    public boolean isGood(int[] nums) {
        if(nums.length-1<1) return false;
        int[] arr=new int[201];
        for(int i=0;i<nums.length;i++){
            arr[nums[i]]++;
        }
        if(arr[nums.length-1]!=2){
            return false;
        }
        for(int i=1;i<nums.length-2;i++){
            if(arr[i]!=1||arr[i]==0){
                return false;
            }
        }
        for(int i=nums.length+1;i<201;i++){
            if(arr[i]>0) return false;
        }
        return true;
    }
}
