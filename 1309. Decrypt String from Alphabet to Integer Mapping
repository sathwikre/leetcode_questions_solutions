class Solution {
    public String freqAlphabets(String s) {
      return find(s)  ;
    }
    static String find(String s){
        StringBuilder ans=new StringBuilder();
        int i=s.length()-1;
        while(i>=0){
            char ch=s.charAt(i);
           if(ch=='#') {
                String a=s.substring(i-2,i);
                int val=Integer.parseInt(a);
                char c=(char)('a'+val-1);
                ans.append(c);
                i -= 3;
           }else{
                int val=Integer.parseInt(ch+"");
                char c=(char)('a'+val-1);
                ans.append(c);
                i=i-1;
           }
        }
        return ans.reverse().toString();
    }
}
