class Solution {
    public boolean checkStraightLine(int[][] coordinates) {
        return find(coordinates);
    }
    static boolean find(int[][] arr){
        if(arr.length<=2) return true;
        for(int i=0;i<arr.length-2;i++){
            int x1=arr[i][0];
            int x2=arr[i+1][0];
            int x3=arr[i+2][0];
            int y1=arr[i][1];
            int y2=arr[i+1][1];
            int y3=arr[i+2][1];
            if(((y2 - y1)*(x3 - x1) != (y3 - y1)*(x2 - x1))){
                return false;
            }
        }
        return true;
    }
}
