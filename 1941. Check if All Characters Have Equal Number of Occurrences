class Solution {
    public boolean areOccurrencesEqual(String s) {
        HashMap<Character,Integer> map=new HashMap<>();
        for(char ch:s.toCharArray()){
            map.put(ch,map.getOrDefault(ch,0)+1);
        }
        int tar = map.get(s.charAt(0));
        for(int freq : map.values()){
            if(freq!=tar){
                return false;
            }
        }
        return true;
    }
}
