class Solution {
    public boolean canMeasureWater(int x, int y, int target) {
        return find(x,y,target);
    }
    static boolean find(int x,int y,int t){
        if(x+y<t){
            return false;
        }
        
        if(t%gcd(x,y)==0){
            return true;
        }
        return false;
    }
    static int gcd(int a,int b){
        if(b==0){
            return a;
        }
        return gcd(b,a%b);
    }
}
