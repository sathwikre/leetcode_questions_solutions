class Solution {
    public int countBalls(int l, int h) {
        int[] arr=new int[46];
        for(int i=l;i<=h;i++){
            arr[digitsum(i)]++;
        }
        int max=0;
        for(int i=0;i<arr.length;i++){
            max=Math.max(max,arr[i]);
        }
        return max;
    }
    static int digitsum(int n){
        int sum=0;
        while(n>0){
            int rem=n%10;
            sum+=rem;
            n=n/10;
        }
        return sum;
    }
}
