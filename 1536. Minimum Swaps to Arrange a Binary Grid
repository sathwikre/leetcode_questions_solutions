class Solution {
    public int minSwaps(int[][] grid) {
        return find(grid);
    }
    static int find(int[][] arr){
        int[] ans=new int[arr.length];
        for(int i=0;i<arr.length;i++){
            int c=0;
            for(int j=arr[0].length-1;j>=0;j--){
                if(arr[i][j]==0){
                    c++;
                }else{
                    break;
                }
            }
            ans[i]=c;
        }
        return bubble(ans);
    }
   static int bubble(int[] arr) {
    int n = arr.length;
    int swaps = 0;

    for (int i = 0; i < n; i++) {
        int required = n - 1 - i;
        int j = i;

        while (j < n && arr[j] < required) {
            j++;
        }

        if (j == n) return -1;

        while (j > i) {
            int temp = arr[j];
            arr[j] = arr[j - 1];
            arr[j - 1] = temp;
            swaps++;
            j--;
        }
    }

    return swaps;
}
}
