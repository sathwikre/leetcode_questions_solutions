class Solution {
    public boolean hasMatch(String s, String p) {
        String[] arr=p.split("\\*");
        int index=0;
        int found;
        for(int i=0;i<arr.length;i++){
            found=s.indexOf(arr[i],index);
            if(found==-1){
                return false;
            }
            index=found+arr[i].length();
        }
        return true;
    }
    
}
