class Solution {
    public int[][] onesMinusZeros(int[][] grid) {
        return find(grid);
    }
    static int[][] find(int[][] arr){
        int m=arr.length;
        int n=arr[0].length;

        int[] row = new int[m];
        int[] col = new int[n];
        int[] row1 = new int[m];
        int[] col1 = new int[n];
        
        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){
                if(arr[i][j] == 1){
                    row[i]++;
                    col[j]++;
                }else{
                    row1[i]++;
                    col1[j]++;
                }
            }
        }
        int[][] ans=new int[m][n];
        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){
               ans[i][j]=row[i]+col[j]-row1[i]-col1[j];
            }
        }
        return ans;
    }
}
