class Solution {
    public int[] getFinalState(int[] arr, int k, int multiplier) {
        for(int i=0;i<k;i++){
            int min=0;
            for(int j=1;j<arr.length;j++){
                if(arr[j]<arr[min]){
                    min=j;
                }
            }
            arr[min]=multiplier*arr[min];
        }
        return arr;
    }
}
