class Solution {
    public boolean findRotation(int[][] mat, int[][] target) {
        int n=mat.length;
        if(Arrays.deepEquals(mat, target)){
                return true;
        }
        for(int k=0;k<4;k++){
             int[][] temp = new int[n][n]; 
            for(int i=0;i<mat.length;i++){
                for(int j=0;j<mat[0].length;j++){
                    temp[j][n - i - 1] = mat[i][j];
                }
            }
            mat = temp; 
            if(Arrays.deepEquals(mat, target)){
                return true;
            }
        }
        return false;
    }
}
