class Solution {
    public String reverseByType(String s) {
        ArrayList<Character> a1=new ArrayList<>();
        ArrayList<Character> a2=new ArrayList<>();
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch>='a'&&ch<='z'){
                a1.add(ch);
            }
            else{
                a2.add(ch);
            }
        }
        int j=a1.size()-1;
        for(int i=0;i<a1.size()/2;i++){
            char t=a1.get(i);
            a1.set(i,a1.get(j));
            a1.set(j,t);
            j--;
        }
        j=a2.size()-1;
        for(int i=0;i<a2.size()/2;i++){
            char t=a2.get(i);
            a2.set(i,a2.get(j));
            a2.set(j,t);
            j--;
        }
        int k=0;
        int l=0;
        StringBuilder sb=new StringBuilder();
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch>='a'&&ch<='z'){
                sb.append(a1.get(k));
                k++;
            }else{
                sb.append(a2.get(l));
                l++;
            }
        }
        return sb.toString();
    }
}
