class Solution {
    public long sumAndMultiply(int n) {
        StringBuilder sb = new StringBuilder();

        while (n > 0) {
            int digit = n % 10;
            if (digit != 0) {
                sb.append(digit);
            }
            n /= 10;
        }

        sb.reverse();

        if (sb.length() == 0) {
            return 0;
        }

        String s = sb.toString();

        int sum = 0;
        for (int i = 0; i < s.length(); i++) {
            sum += s.charAt(i) - '0';
        }

        long num = Long.parseLong(s);
        return num * sum;
    }
}
