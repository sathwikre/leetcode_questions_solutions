class Solution {
    public int smallestNumber(int n) {
        int x=n;
       while(true) {
        if(bits(x)== (int)(Math.log(n) / Math.log(2)) + 1){
            return x;
        }
        x++;
       }
    }
    static int bits(int n){
        int c=0;
        while(n>0){
            int b=n&1;
            n=n>>1;
            if(b==1) c++;
        }
        return c;
    }
}
