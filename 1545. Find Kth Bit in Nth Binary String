class Solution {
    public char findKthBit(int n, int k) {
        StringBuilder sb = new StringBuilder("0");

        for (int i = 2; i <= n; i++) {
            StringBuilder temp = new StringBuilder(sb); 
            for (int j = 0; j < temp.length(); j++) {
                if (temp.charAt(j) == '0')
                    temp.setCharAt(j, '1');
                else
                    temp.setCharAt(j, '0');
            }

            temp.reverse(); 
            sb.append("1");
            sb.append(temp); 
        }

        return sb.charAt(k - 1);
    }
}
