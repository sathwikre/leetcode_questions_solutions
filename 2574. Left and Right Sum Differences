class Solution {
    public int[] leftRightDifference(int[] nums) {
        int[] a1=new int[nums.length];
        int[] a2=new int[nums.length];
        int[] ans=new int[nums.length];
        int s1=0;
        for(int i=0;i<nums.length;i++){
            s1+=nums[i];
            a1[i]=s1-nums[i];
        }
        int s2=0;
        for(int i=nums.length-1;i>=0;i--){
            s2+=nums[i];
            a2[i]=s2-nums[i];
        }
        for(int i=0;i<nums.length;i++){
            ans[i]=Math.abs(a1[i]-a2[i]);
        }
        return ans;
    }
}
