class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        ArrayList<Integer> s=new ArrayList<>();
        ArrayList<Integer> g=new ArrayList<>();
        int c=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<pivot){
                s.add(nums[i]);
            }else if(nums[i]>pivot){
                g.add(nums[i]);
            }else{
                c++;
            }
        }
        int[] ans=new int[nums.length];
        int i=0;
        int j=0;
        int h=0;
        while(i<nums.length){
           while(j<s.size()){
            ans[i++]=s.get(j);
            j++;
           }
           for(int k=0;k<c;k++){
            ans[i++]=pivot;
           }
           while(h<g.size()){
            ans[i++]=g.get(h);
            h++;
           }
        }
        return ans;
    }
}
