/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     public int val;
 *     public ListNode next;
 *     public ListNode(int val=0, ListNode next=null) {
 *         this.val = val;
 *         this.next = next;
 *     }
 * }
 */
public class Solution {
    public ListNode RotateRight(ListNode head, int k) {
        if (head == null || head.next == null || k == 0) {
            return head;
        }
        ListNode t1=head;
        int length=1;
        while(t1.next!=null){
            t1=t1.next;
            length++;
        }
        k=k%length;
        if(k==0){
            return head;
        }
        int n=(length-k-1)%length;
        ListNode t2=head;
        for(int i=0;i<n;i++){
            t2=t2.next;
        }
        ListNode curhead=head;
        if(t2.next!=null){
            curhead=t2.next;
        }
        t2.next=null;
        t1.next=head;
        return head=curhead;

    }
}
