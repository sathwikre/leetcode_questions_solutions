class Solution {
    public int numberOfSpecialChars(String word) {
        HashMap<Character,List<Integer>> ans=new HashMap<>();
        for(int i=0;i<word.length();i++){
            if(word.charAt(i)>='a'&&word.charAt(i)<='z'){
                ans.put(word.charAt(i),new ArrayList<>());
            }
        }
        for(int i=0;i<word.length();i++){
            if(word.charAt(i)>='a'&&word.charAt(i)<='z'){
               List<Integer> list = ans.get(word.charAt(i));
               if (list.isEmpty()) {
                    list.add(i); 
                } else {
                    list.set(0, i); 
                }
            }else{
                char ch=(char)(word.charAt(i)+'a'-'A');
                 if (ans.containsKey(ch)) {
                    List<Integer> list = ans.get(ch);
                    
                    
                    if (list.isEmpty()) {
                        list.add(-1); 
                    }
                    
                    if (list.size() == 1) {
                        list.add(i); 
                    }
            }
        }
        }
        int c=0;
        for(List<Integer> arr:ans.values()){
           if (arr.size() == 2 && arr.get(0) != -1 && arr.get(0) < arr.get(1)) {
                c++;
            }
        }
        return c;
    }

}
